# ===== LLM providers (at least one required for real agent runs) =====
OPENAI_API_KEY=
GROQ_API_KEY=

# ===== Threat-intel providers (optional) =====
NVD_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=

# ===== Runtime =====
CHROMA_PATH=./chroma_db
LOG_LEVEL=INFO

# ===== CORS =====
# Comma-separated list of allowed origins. Use your frontend URL in prod.
# Example: CORS_ORIGINS=https://cyber-sentinel.vercel.app,https://staging.example.com
# Leave empty to default to http://localhost:3000
CORS_ORIGINS=
FRONTEND_URL=http://localhost:3000
